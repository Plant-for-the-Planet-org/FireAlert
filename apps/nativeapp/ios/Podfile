require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

require_relative '../../../node_modules/@react-native-community/cli-platform-ios/native_modules'

platform :ios, '15.1'

ENV['RCT_NEW_ARCH_ENABLED'] = '0'

prepare_react_native_project!

$RNMapboxMapsImpl = 'mapbox'

linkage = ENV['USE_FRAMEWORKS']
if linkage
  use_frameworks! :linkage => linkage.to_sym
else
  # Static linkage required for Reanimated 3.x C++ modules
  use_frameworks! :linkage => :static
end

target 'FireAlert' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  pre_install do |installer|
    $RNMapboxMaps.pre_install(installer)
  end

  post_install do |installer|
    $RNMapboxMaps.post_install(installer)

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
        config.build_settings['CLANG_WARN_NON_MODULAR_INCLUDE_IN_FRAMEWORK_MODULE'] = 'NO'

        flags = config.build_settings['OTHER_CFLAGS']
        if flags.is_a?(Array)
          config.build_settings['OTHER_CFLAGS'] = flags.reject { |f|
            f == '-Werror=non-modular-include-in-framework-module'
          }
        elsif flags.is_a?(String)
          config.build_settings['OTHER_CFLAGS'] = flags
            .split(' ')
            .reject { |f| f == '-Werror=non-modular-include-in-framework-module' }
            .join(' ')
        end

        if target.name == 'MapboxMaps' || target.name.start_with?('RNMapbox')
          config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
        end

        if target.name == 'fmt'
          # Workaround for Apple Clang + fmt 11 consteval failures.
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'

          definitions = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
          definitions = ['$(inherited)'] if definitions.nil?
          definitions = definitions.split(' ') if definitions.is_a?(String)
          unless definitions.include?('FMT_USE_CONSTEVAL=0')
            definitions << 'FMT_USE_CONSTEVAL=0'
          end
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions
        end
      end
    end
  end
end

target 'OneSignalNotificationServiceExtension' do
  platform :ios, '15.1'
  pod 'OneSignalXCFramework', '>= 5.0.0', '< 6.0'
end
